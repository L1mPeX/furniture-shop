<!DOCTYPE html>
<html lang="ru">
<%- include('partials/head', { title: 'Интерьер - магазин мебели' }) %>

    <body>
        <%- include('partials/header') %>

            <% if (orderSuccess) { %>
                <div class="alert alert-success alert-dismissible fade show mb-0 text-center" role="alert">
                    <div class="container">
                        <i class="fas fa-check-circle me-2"></i>
                        Ваш заказ #<%= orderSuccess %> успешно оформлен!
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
                <% } %>

                    <!-- Главный баннер -->
                    <div class="hero-banner bg-light py-5 mb-5">
                        <div class="container">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <h1 class="display-4 fw-bold mb-4">Создайте свой идеальный интерьер</h1>
                                    <p class="lead mb-4">Широкий ассортимент мебели для дома и офиса по доступным ценам
                                    </p>
                                    <a href="/catalog" class="btn btn-orange btn-lg">В каталог</a>
                                </div>
                                <div class="col-md-6">
                                    <img src="https://www.ikea.com/images/0a/1b/0a1b6a3a4a5b6c7d8e9f0a1b2c3d4e5f.jpg"
                                        alt="Мебель" class="img-fluid rounded">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Категории -->
                    <div class="container mb-5">
                        <h2 class="text-center mb-4">Категории товаров</h2>
                        <div class="row">
                            <% categories.forEach(category=> { %>
                                <div class="col-md-3 mb-4">
                                    <div class="card h-100">
                                        <img src="https://www.ikea.com/images/<%= category.toLowerCase() %>-category.jpg"
                                            class="card-img-top" alt="<%= category %>"
                                            style="height: 200px; object-fit: cover;">
                                        <div class="card-body text-center">
                                            <h5 class="card-title">
                                                <%= category %>
                                            </h5>
                                            <a href="/catalog?category=<%= encodeURIComponent(category) %>"
                                                class="btn btn-outline-orange mt-2">Смотреть</a>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                    </div>

                    <!-- Популярные товары -->
                    <div class="bg-light py-5">
                        <div class="container">
                            <h2 class="text-center mb-5">Популярные товары</h2>
                            <div class="row">
                                <% popularProducts.forEach(product=> { %>
                                    <div class="col-md-3 mb-4">
                                        <div class="card h-100">
                                            <img src="<%= product.image %>" class="card-img-top"
                                                alt="<%= product.name %>" style="height: 200px; object-fit: cover;">
                                            <div class="card-body">
                                                <h5 class="card-title">
                                                    <%= product.name %>
                                                </h5>
                                                <p class="card-text text-orange fw-bold">
                                                    <%= product.price.toLocaleString() %> руб.
                                                </p>
                                                <div class="d-grid gap-2">
                                                    <a href="/product/<%= product.id %>"
                                                        class="btn btn-outline-orange">Подробнее</a>
                                                    <form action="/cart/add" method="post" class="mt-2">
                                                        <input type="hidden" name="productId" value="<%= product.id %>">
                                                        <button type="submit" class="btn btn-orange w-100">
                                                            <i class="fas fa-cart-plus me-2"></i>В корзину
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <div class="text-center mt-4">
                                <a href="/catalog" class="btn btn-orange btn-lg">Весь каталог</a>
                            </div>
                        </div>
                    </div>

                    <!-- Преимущества -->
                    <div class="container my-5">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <div class="text-center p-4 border rounded h-100">
                                    <i class="fas fa-truck fa-3x text-orange mb-3"></i>
                                    <h3>Быстрая доставка</h3>
                                    <p>По Москве - 1-2 дня, по России - до 10 дней</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-4 border rounded h-100">
                                    <i class="fas fa-medal fa-3x text-orange mb-3"></i>
                                    <h3>Гарантия качества</h3>
                                    <p>Все товары проходят строгий контроль перед отправкой</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-center p-4 border rounded h-100">
                                    <i class="fas fa-headset fa-3x text-orange mb-3"></i>
                                    <h3>Поддержка 24/7</h3>
                                    <p>Наши менеджеры всегда готовы помочь</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <%- include('partials/footer') %>

                        <!-- Скрипты -->
                        <script
                            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                        <script>
                            // Закрытие уведомления через 5 секунд
                            setTimeout(() => {
                                const alert = document.querySelector('.alert');
                                if (alert) {
                                    const bsAlert = new bootstrap.Alert(alert);
                                    bsAlert.close();
                                }
                            }, 5000);
                        </script>
    </body>

</html>