<!DOCTYPE html>
<html lang="ru">
<%- include('partials/head', { title: 'Корзина | Интерьер' }) %>

    <body>
        <%- include('partials/header') %>

            <div class="container my-5">
                <h1 class="mb-4">Корзина</h1>

                <% if (cartItems.length===0) { %>
                    <div class="alert alert-info">
                        Ваша корзина пуста. <a href="/catalog" class="alert-link">Перейти в каталог</a>
                    </div>
                    <% } else { %>
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card">
                                    <div class="card-body">
                                        <% cartItems.forEach(item=> { %>
                                            <div class="d-flex mb-4 pb-4 border-bottom">
                                                <div class="flex-shrink-0">
                                                    <img src="<%= item.product.image %>" class="rounded" width="120"
                                                        alt="<%= item.product.name %>">
                                                </div>
                                                <div class="flex-grow-1 ms-3">
                                                    <h5 class="mt-0">
                                                        <%= item.product.name %>
                                                    </h5>
                                                    <p class="text-muted">
                                                        <%= item.product.category %>
                                                    </p>
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <form action="/cart/update" method="post"
                                                            class="d-flex align-items-center">
                                                            <input type="hidden" name="itemId" value="<%= item.id %>">
                                                            <div class="input-group" style="width: 120px;">
                                                                <button class="btn btn-outline-secondary" type="button"
                                                                    onclick="this.parentNode.querySelector('input[type=number]').stepDown()">-</button>
                                                                <input type="number" name="quantity"
                                                                    class="form-control text-center"
                                                                    value="<%= item.quantity %>" min="1">
                                                                <button class="btn btn-outline-secondary" type="button"
                                                                    onclick="this.parentNode.querySelector('input[type=number]').stepUp()">+</button>
                                                            </div>
                                                            <button type="submit"
                                                                class="btn btn-link text-orange ms-2">Обновить</button>
                                                        </form>
                                                        <div class="text-end">
                                                            <h5 class="mb-0">
                                                                <%= item.total.toLocaleString() %> руб.
                                                            </h5>
                                                            <small class="text-muted">
                                                                <%= item.product.price.toLocaleString() %> руб./шт.
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                                <form action="/cart/remove" method="post" class="ms-2">
                                                    <input type="hidden" name="itemId" value="<%= item.id %>">
                                                    <button type="submit" class="btn btn-link text-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                            <% }); %>

                                                <div class="d-flex justify-content-between">
                                                    <a href="/catalog" class="btn btn-outline-secondary">Продолжить
                                                        покупки</a>
                                                    <a href="/cart/clear" class="btn btn-outline-danger">Очистить
                                                        корзину</a>
                                                </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-header bg-orange text-white">
                                        Итого
                                    </div>
                                    <div class="card-body">
                                        <table class="table">
                                            <tbody>
                                                <tr>
                                                    <td>Товары (<%= cartItems.reduce((sum, item)=> sum + item.quantity,
                                                            0) %>)</td>
                                                    <td class="text-end">
                                                        <%= total.toLocaleString() %> руб.
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Доставка</td>
                                                    <td class="text-end">Бесплатно</td>
                                                </tr>
                                                <tr class="fw-bold">
                                                    <td>Всего</td>
                                                    <td class="text-end">
                                                        <%= total.toLocaleString() %> руб.
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <form action="/cart/confirm" method="post">
                                            <button type="submit" class="btn btn-orange w-100">Подтвердить
                                                заказ</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>
            </div>

            <%- include('partials/footer') %>
                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>

</html>